#!/usr/bin/env bash

set -euo pipefail

action="${1:-}"
model_path="${2:-}"
language="${3:-en}"
auto_insert="${4:-1}"
runtime_dir="${XDG_RUNTIME_DIR:-/tmp}/hype-voice-input"
audio_file="$runtime_dir/recording.wav"
pid_file="$runtime_dir/recorder.pid"
output_base="$runtime_dir/transcript"

mkdir -p "$runtime_dir"

find_model() {
    if [ -n "$model_path" ] && [ -r "$model_path" ]; then
        printf '%s\n' "$model_path"
        return
    fi
    for candidate in \
        "$HOME/.local/share/whisper.cpp/models/ggml-base.en.bin" \
        "$HOME/.local/share/whisper/models/ggml-base.en.bin" \
        "/usr/share/whisper.cpp-model-base.en/ggml-base.en.bin" \
        "/usr/share/whisper.cpp/models/ggml-base.en.bin"
    do
        if [ -r "$candidate" ]; then
            printf '%s\n' "$candidate"
            return
        fi
    done
    return 1
}

stop_recorder() {
    [ -r "$pid_file" ] || return 0
    recorder_pid="$(cat "$pid_file")"
    if kill -0 "$recorder_pid" 2>/dev/null; then
        kill -INT "$recorder_pid" 2>/dev/null || true
        for _ in $(seq 1 30); do
            kill -0 "$recorder_pid" 2>/dev/null || break
            sleep 0.1
        done
    fi
    rm -f "$pid_file"
}

case "$action" in
    start)
        command -v pw-record >/dev/null 2>&1 || { echo "pw-record is required (PipeWire)." >&2; exit 2; }
        command -v whisper-cli >/dev/null 2>&1 || { echo "whisper-cli is required (whisper.cpp)." >&2; exit 2; }
        find_model >/dev/null || { echo "Choose a whisper.cpp GGML model in Voice Input settings." >&2; exit 2; }
        stop_recorder
        rm -f "$audio_file" "$output_base.txt"
        pw-record --format s16 --rate 16000 --channels 1 "$audio_file" >/dev/null 2>&1 &
        echo "$!" > "$pid_file"
        echo "LISTENING"
        ;;
    stop)
        stop_recorder
        [ -s "$audio_file" ] || { echo "No microphone audio was captured." >&2; exit 3; }
        resolved_model="$(find_model)" || { echo "Whisper model is unavailable." >&2; exit 2; }
        whisper-cli -m "$resolved_model" -f "$audio_file" -l "$language" -nt -np -otxt -of "$output_base" >/dev/null
        transcript="$(sed 's/^[[:space:]]*//; s/[[:space:]]*$//' "$output_base.txt" | tr '\n' ' ' | sed 's/[[:space:]][[:space:]]*/ /g')"
        [ -n "$transcript" ] || { echo "No speech was detected." >&2; exit 4; }
        printf 'TRANSCRIPT\n%s\n' "$transcript"
        printf '%s' "$transcript" | wl-copy 2>/dev/null || true
        if [ "$auto_insert" = "1" ]; then
            if command -v wtype >/dev/null 2>&1; then
                wtype -- "$transcript"
            elif command -v hyprctl >/dev/null 2>&1 && command -v wl-copy >/dev/null 2>&1; then
                hyprctl dispatch sendshortcut CTRL,V,activewindow >/dev/null
            else
                echo "Transcript copied; install wtype to type into the focused field." >&2
            fi
        fi
        ;;
    cancel)
        stop_recorder
        rm -f "$audio_file" "$output_base.txt"
        echo "CANCELLED"
        ;;
    *)
        echo "Usage: voice-input {start|stop|cancel} [model] [language] [auto-insert]" >&2
        exit 2
        ;;
esac
